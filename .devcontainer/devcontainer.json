{
  "name": "Angular Axon Core Dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        }
      },
      "extensions": [
        "Angular.ng-template",              // Angular Language Service
        "dbaeumer.vscode-eslint",           // ESLint support
        "esbenp.prettier-vscode",           // Prettier
        "vitest.explorer",                  // Vitest runner integration
        "editorconfig.editorconfig"         // Consistency
      ]
    }
  },
  // Forward the Angular serve port
  "forwardPorts": [4200],

  // Run npm install automatically after the container is created
  "postCreateCommand": "npm install",

  // Ensure we run as the non-root 'node' user for security/permission consistency
  "remoteUser": "node"
}