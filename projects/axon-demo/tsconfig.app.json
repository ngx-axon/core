{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "rootDir": "src",
    "baseUrl": "./",
    "types": [],
    "paths": {
      "@ngx-axon/core": [
        "../../dist/axon" 
      ],
      "@ngx-axon/core/*": [
        "../../dist/axon/*"
      ]
    }
  },
  "files": [
    "src/main.ts"
  ],
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts"
  ]
}
